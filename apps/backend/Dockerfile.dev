# syntax=docker/dockerfile:1.7

FROM node:22-alpine
RUN corepack enable
WORKDIR /repo

# Install workspace deps. Source is bind-mounted by docker-compose.dev.yml.
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json turbo.json tsconfig.base.json ./
COPY apps/backend/package.json ./apps/backend/
COPY packages/shared/package.json ./packages/shared/
RUN pnpm install --frozen-lockfile --filter backend...

WORKDIR /repo/apps/backend
EXPOSE 3001

# tsx watch reloads on change. Migrations + optional seed run once on container start.
CMD ["sh", "-c", "pnpm db:migrate && { [ \"$SEED_ON_BOOT\" = \"true\" ] && pnpm db:seed || true; } && pnpm dev"]
