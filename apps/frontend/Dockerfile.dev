# syntax=docker/dockerfile:1.7

FROM node:22-alpine
RUN corepack enable
WORKDIR /repo

# Install workspace deps. Source is bind-mounted by docker-compose.dev.yml.
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json turbo.json tsconfig.base.json ./
COPY apps/frontend/package.json ./apps/frontend/
COPY packages/shared/package.json ./packages/shared/
COPY packages/ui/package.json ./packages/ui/
RUN pnpm install --frozen-lockfile --filter frontend...

WORKDIR /repo/apps/frontend
EXPOSE 3000

# Next.js dev server. -H 0.0.0.0 so the port mapping works.
# Turbopack ignores WATCHPACK_POLLING; webpack mode is used here so file
# changes propagated across the podman/macOS virtiofs boundary trigger reloads.
CMD ["pnpm", "exec", "next", "dev", "-H", "0.0.0.0"]
